{
	"name": "@eams-monorepo/vue-element-cui-nuxt",
	"description": "EAMS Vue Element CUI Nuxt Documentation Site",
	"homepage": "https://vec.ruan-cat.com",
	"version": "3.0.0",
	"type": "module",
	"scripts": {
		"dev": "nuxt dev",
		"predev": "nuxt prepare",
		"prebuild": "nuxt prepare",
		"build": "pnpm run build:vercel",
		"build:docs": "pnpm run build:vercel",
		"build:vercel": "cross-env NODE_OPTIONS=--max-old-space-size=8192 nuxi build --preset vercel",
		"turbo:build:vercel": "turbo run move-vercel-output-to-root --filter=@eams-monorepo/vue-element-cui-nuxt",
		"move-vercel-output-to-root": "move-vercel-output-to-root",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"test": "vitest run --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"postinstall": "nuxt prepare"
	},
	"dependencies": {
		"@eams-monorepo/vue-element-cui": "workspace:*",
		"element-plus": "^2.13.5",
		"entities": "^7.0.1",
		"nuxt": "^3.21.2",
		"shadcn-docs-nuxt": "^1.1.9",
		"std-env": "^3.10.0",
		"tailwindcss": "^4.2.1",
		"tailwindcss-animate": "^1.0.7",
		"vue": "^3.5.30",
		"vue-router": "^4.6.4"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.2.98",
		"@ruan-cat/utils": "^4.25.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vue/test-utils": "^2.4.6",
		"cross-env": "^10.1.0",
		"jsdom": "^25.0.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	}
}
