{
	// === 编辑器格式化配置 ===
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",

	// Auto fix
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit",
		"source.organizeImports": "never"
	},

	// === 配置语言的文件关联 ===
	"files.associations": {
		".cursorignore": "ignore",
		"pages.json": "jsonc", // pages.json 可以写注释
		"manifest.json": "jsonc" // manifest.json 可以写注释
	},

	"css.validate": false, // 禁用 CSS 内置验证
	"scss.validate": false, // 禁用 SCSS 内置验证
	"less.validate": false, // 禁用 LESS 内置验证

	// === ESLint 配置 ===

	// Silent the stylistic rules in you IDE, but still auto fix them
	"eslint.rules.customizations": [
		{ "rule": "style/*", "severity": "off", "fixable": true },
		{ "rule": "format/*", "severity": "off", "fixable": true },
		{ "rule": "*-indent", "severity": "off", "fixable": true },
		{ "rule": "*-spacing", "severity": "off", "fixable": true },
		{ "rule": "*-spaces", "severity": "off", "fixable": true },
		{ "rule": "*-order", "severity": "off", "fixable": true },
		{ "rule": "*-dangle", "severity": "off", "fixable": true },
		{ "rule": "*-newline", "severity": "off", "fixable": true },
		{ "rule": "*quotes", "severity": "off", "fixable": true },
		{ "rule": "*semi", "severity": "off", "fixable": true }
	],

	// Enable eslint for all supported languages
	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact",
		"vue",
		"html",
		"markdown",
		"json",
		"jsonc",
		"yaml",
		"toml",
		"xml",
		"gql",
		"graphql",
		"astro",
		"svelte",
		"css",
		"less",
		"scss",
		"pcss",
		"postcss"
	],

	// === 终端配置 ===
	"terminal.integrated.cwd": "${workspaceFolder}",
	"terminal.integrated.splitCwd": "workspaceRoot",

	// === 搜索排除 ===
	"search.exclude": {
		"**/dist": true,
		"**/.cache": true,
		"**/.temp": true,
		"**/.vercel": true,
		"**/.turbo": true,
		"**/cache": true,
		"**/.vitepress/cache/**": true,
		"**/.nuxt/**": true
	},

	// === 文件监视排除 ===
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.turbo/**": true,
		"**/node_modules/*/**": true,
		"**/dist/**": true,
		"**/.changeset/**": true
	},

	// === Vue 语言服务 ===
	"vue.server.includeLanguages": ["vue"],

	// === 图标相关 ===
	"iconify.annotations": true,
	"iconify.inplace": true,

	// === 代码运行 ===
	"code-runner.executorMap": {
		"typescript": "pnpm dotenvx run -- tsx $fullFileName"
	},

	// === Git Graph 分支过滤 ===
	"git-graph.customBranchGlobPatterns": [
		{
			"name": "f1小组分支",
			"glob": "*f1*"
		}
	],

	// === i18n 路径配置 ===
	"i18n-ally.localesPaths": [
		"apps/eams-frontend/src/components/mybpmn/i18n",
		"apps/eams-frontend/src/components/mybpmn/i18n/language"
	],

	// === 文件嵌套 ===
	// Enable file nesting
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.patterns": {
		"CLAUDE.md": "GEMINI.md,AGENTS.md",
		"tsconfig.json": "tsconfig.*.json, env.d.ts",
		"vite.config.*": "jsconfig*, vitest.config.*, cypress.config.*, playwright.config.*, pages.config.*, manifest.config.*, uno.config.*, volar.config.*, *.env, .env.*, alova.config.*",
		"package.json": "package-lock.json, pnpm*, .yarnrc*, yarn*, .eslint*, eslint*, .prettier*, prettier*, .editorconfig, tsconfig.json, LICENSE, .gitattributes, .gitignore, .gitpod.yml, CNAME, .npmrc, .browserslistrc, .nvmrc, renovate.json",
		".env": ".env*",
		"README.md": "index.html, favicon.ico, robots.txt, CHANGELOG.md",
		".git-cz.json": ".versionrc",
		"eslint.config.mjs": ".commitlintrc.*, .prettier*, .editorconfig, commitlint.*, .eslint*"
	}
}
